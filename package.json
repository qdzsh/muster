{
  "name": "muster",
  "displayName": "Muster",
  "version": "0.1.0",
  "publisher": "tlelabs",
  "license": "MIT",
  "description": "Muster — an open-source coordinator for multiple AI CLIs (Claude, Grok, Codex, Antigravity) with streaming and session resume",
  "repository": {
    "type": "git",
    "url": "https://github.com/lploc94/muster.git"
  },
  "bugs": {
    "url": "https://github.com/lploc94/muster/issues"
  },
  "homepage": "https://github.com/lploc94/muster#readme",
  "keywords": [
    "vscode-extension",
    "claude",
    "grok",
    "codex",
    "antigravity",
    "mcp",
    "ai-cli",
    "coordinator"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "muster.openChat",
        "title": "Muster: Open Chat"
      }
    ],
    "configuration": {
      "title": "Muster",
      "properties": {
        "muster.retention.maxTurnsPerTask": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "Maximum persisted turns retained per terminal task."
        },
        "muster.retention.maxStoredOutputChars": {
          "type": "number",
          "default": 200000,
          "minimum": 1024,
          "description": "Maximum stored assistant output characters per settled turn on open tasks."
        },
        "muster.permissions.mode": {
          "type": "string",
          "enum": ["ask", "allow", "readonly"],
          "default": "ask",
          "enumDescriptions": [
            "Safe: auto-allow read-only tool calls, prompt for writes/commands/unknown actions.",
            "Auto-approve every tool-permission request (least safe; still audit-logged).",
            "Allow read-only tool calls, deny all writes/commands without prompting."
          ],
          "description": "How Muster handles agent tool-permission requests. 'ask' (safe): auto-allow read-only, prompt for writes/commands. 'allow': auto-approve everything (less safe). 'readonly': deny all writes/commands."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "muster",
          "title": "Muster",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "muster": [
        {
          "type": "webview",
          "id": "muster.chat",
          "name": "Muster"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p . && npm run build:webview",
    "watch": "tsc -watch -p .",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch:webview": "vite build --config webview/vite.config.ts --watch",
    "vscode:prepublish": "npm run compile",
    "mvp:claude": "tsx scripts/test-claude.ts",
    "mvp:grok": "tsx scripts/test-grok.ts",
    "mvp:kiro": "tsx scripts/test-kiro.ts",
    "mvp:codex": "tsx scripts/test-codex.ts",
    "mvp:opencode": "tsx scripts/test-opencode.ts",
    "vendor:codex-acp": "node scripts/vendor-codex-acp.mjs",
    "vendor:claude-acp": "node scripts/vendor-claude-acp.mjs",
    "mvp:task": "tsx scripts/test-task.ts",
    "mvp:bridge": "tsx scripts/test-bridge.ts",
    "test:agy-ask": "node scripts/test-agy-ask-mcp.mjs",
    "test": "vitest run",
    "test:task-audit": "node --test scripts/verify-task-model-ui-state-audit.test.mjs",
    "test:settings-docs": "node --test scripts/verify-settings-docs.test.mjs",
    "test:webview": "playwright test e2e/muster-webview-state.spec.ts",
    "test:presentation-integration": "vitest run src/task/presentation-tool-auth.test.ts src/host/presentation-tool-router.test.ts src/host/presentation-manager.test.ts src/host/presentation-panel-adapter.test.ts src/host/presentation-chat-link.test.ts src/host/presentation-revision-loop.test.ts src/host/webview-security.test.ts && npm run compile && npm run test:webview -- e2e/muster-presentation.spec.ts",
    "test:presentation-live-evidence": "node --test scripts/verify-presentation-live-host-evidence.test.mjs",
    "test:presentation-docs": "node --test scripts/verify-presentation-docs.test.mjs",
    "test:watch": "vitest",
    "check:svelte": "svelte-check --workspace webview --tsconfig ./tsconfig.json",
    "test:source-boundary": "node scripts/source-boundary-smoke.mjs",
    "test:evidence": "node --test scripts/verify-verification-evidence.test.mjs",
    "test:source-boundary:fixtures": "node --test scripts/source-boundary-smoke.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3.9.2",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/typography": "^0.5.20",
    "@vscode-elements/elements": "^2.5.1",
    "dompurify": "^3.4.11",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "mermaid": "^11.16.0"
  }
}
