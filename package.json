{
  "name": "muster",
  "displayName": "Muster",
  "version": "0.1.0",
  "publisher": "tlelabs",
  "license": "MIT",
  "description": "Muster — an open-source coordinator for multiple AI CLIs (Claude, Grok, Codex, Antigravity) with streaming and session resume",
  "repository": {
    "type": "git",
    "url": "https://github.com/lploc94/muster.git"
  },
  "bugs": {
    "url": "https://github.com/lploc94/muster/issues"
  },
  "homepage": "https://github.com/lploc94/muster#readme",
  "keywords": [
    "vscode-extension",
    "claude",
    "grok",
    "codex",
    "antigravity",
    "mcp",
    "ai-cli",
    "coordinator"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "muster.openChat",
        "title": "Muster: Open Chat"
      },
      {
        "command": "muster.sendToClaude",
        "title": "Muster: Send to Claude (quick)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "muster",
          "title": "Muster",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "muster": [
        {
          "type": "webview",
          "id": "muster.chat",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p . && npm run build:webview",
    "watch": "tsc -watch -p .",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch:webview": "vite build --config webview/vite.config.ts --watch",
    "vscode:prepublish": "npm run compile",
    "mvp:claude": "tsx scripts/test-runner.ts",
    "mvp:grok": "tsx scripts/test-grok.ts",
    "mvp:task": "tsx scripts/test-task.ts",
    "mvp:bridge": "tsx scripts/test-bridge.ts",
    "test:agy-ask": "node scripts/test-agy-ask-mcp.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3.9.2",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode-elements/elements": "^2.5.1"
  }
}
