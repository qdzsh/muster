{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node", "vscode"]
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["**/*.test.ts", "**/*.testkit.ts", "vitest.config.ts"]
}
